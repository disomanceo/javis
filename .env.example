ANTHROPIC_API_KEY=replace_with_claude_api_key
CLAUDE_MODEL=claude-sonnet-4-5
GEMINI_API_KEY=replace_with_gemini_api_key
GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts
GEMINI_TTS_VOICE=Kore
THONBURIAN_TTS_URL=
THONBURIAN_TTS_MODEL=ThonburianTTS
THONBURIAN_TTS_API_KEY=
# Example after deploying mms-tts-server:
# MMS_TTS_URL=https://your-space-name.hf.space/synthesize
MMS_TTS_URL=
MMS_TTS_MODEL=facebook/mms-tts-tha
MMS_TTS_API_KEY=

# Firebase Admin for Vercel/server runtime.
# Option A: paste the entire service account JSON as one line.
FIREBASE_SERVICE_ACCOUNT_JSON={"project_id":"your-project-id","client_email":"firebase-adminsdk@example.iam.gserviceaccount.com","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"}

# Option B: use separate variables instead.
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@example.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
